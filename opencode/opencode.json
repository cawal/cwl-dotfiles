// https://opencode.ai/docs/config/
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "stripe": {
      "type": "remote",
      "url": "https://mcp.stripe.com",
      "enabled": false
    },
    "turi-supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?read_only=true",
      "enabled": false
    },
    "turi-grafana": {
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_API_KEY": "{env:TURI_GRAFANA_API_KEY}",
        "GRAFANA_URL": "{env:TURI_GRAFANA_URL}"
      },
      "enabled": false
    }
  },
  "instructions": ["CONTRIBUTING.md", "docs/guidelines.md", ".cursor/rules/*.md","CLAUDE.md"],
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "patch": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "question": "allow",
  },
}
